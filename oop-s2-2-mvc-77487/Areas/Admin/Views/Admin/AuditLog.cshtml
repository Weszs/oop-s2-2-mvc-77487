@using oop_s2_2_mvc_77487.Services
@model IEnumerable<AuditLogEntry>

@{
    ViewData["Title"] = "Audit Log";
}

<div class="container-fluid mt-3">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Full Audit Log</h1>
            <p class="text-muted">Complete record of all tracked user actions in the system</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Admin</a>
            <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary">Dashboard</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Timestamp (UTC)</th>
                            <th>User ID</th>
                            <th>Action</th>
                            <th>Entity Type</th>
                            <th>Entity ID</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model)
                        {
                            <tr>
                                <td>@entry.Id</td>
                                <td><small>@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</small></td>
                                <td><small class="text-muted">@entry.UserId</small></td>
                                <td>
                                    @{
                                        var badgeClass = entry.Action switch
                                        {
                                            "Login" => "bg-success",
                                            "Logout" => "bg-secondary",
                                            "LoginFailed" => "bg-danger",
                                            "LoginLockedOut" => "bg-warning text-dark",
                                            "Register" => "bg-info",
                                            "ViewAuditLog" => "bg-dark",
                                            _ => "bg-primary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@entry.Action</span>
                                </td>
                                <td>@entry.EntityType</td>
                                <td>@(entry.EntityId?.ToString() ?? "-")</td>
                                <td><small>@entry.Details</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    <h4>No audit entries recorded yet</h4>
                    <p>Actions will appear here as users interact with the system.</p>
                </div>
            }
        </div>
    </div>

    <div class="mt-3 text-muted text-center">
        <small>Showing @Model.Count() most recent entries. Audit data is also written to Serilog file logs in <code>logs/</code>.</small>
    </div>
</div>
