@model IEnumerable<oop_s2_2_mvc_77487.Models.FollowUp>

@{
    ViewData["Title"] = "Follow-ups";
}

<div class="container mt-5">
    <div class="row mb-3">
        <div class="col-md-6">
            <h1>Follow-ups</h1>
        </div>
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
            {
                <a asp-action="Create" class="btn btn-primary">Create New Follow-up</a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Premises</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Closed Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.Status == oop_s2_2_mvc_77487.Models.FollowUpStatus.Open && item.DueDate < DateTime.Now ? "table-warning" : "")">
                        <td>@item.Inspection?.Premises?.Name</td>
                        <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge bg-@(item.Status == oop_s2_2_mvc_77487.Models.FollowUpStatus.Open ? "warning" : "success")">
                                @item.Status
                            </span>
                        </td>
                        <td>@(item.ClosedDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                            {
                                @if (item.Status == oop_s2_2_mvc_77487.Models.FollowUpStatus.Open)
                                {
                                    <a asp-action="Close" asp-route-id="@item.Id" class="btn btn-sm btn-success">Close</a>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No follow-ups found.</div>
    }
</div>
