@model oop_s2_2_mvc_77487.Models.FollowUp

@{
    ViewData["Title"] = "Create Follow-up";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1>Create Follow-up</h1>

            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label asp-for="InspectionId" class="form-label"></label>
                    <select asp-for="InspectionId" class="form-select" asp-items="ViewBag.InspectionId">
                        <option value="">Select Inspection</option>
                    </select>
                    <span asp-validation-for="InspectionId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DueDate" class="form-label"></label>
                    <input asp-for="DueDate" class="form-control" type="date" />
                    <small class="form-text text-muted">Due date must be after the inspection date</small>
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
