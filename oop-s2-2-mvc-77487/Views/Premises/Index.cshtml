@model IEnumerable<oop_s2_2_mvc_77487.Models.Premises>

@{
    ViewData["Title"] = "Premises";
}

<div class="container mt-5">
    <div class="row mb-3">
        <div class="col-md-6">
            <h1>Premises</h1>
        </div>
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary">Add New Premises</a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Town</th>
                    <th>Risk Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Address</td>
                        <td>@item.Town</td>
                        <td>
                            <span class="badge bg-@(item.RiskRating == oop_s2_2_mvc_77487.Models.RiskRating.Low ? "success" : item.RiskRating == oop_s2_2_mvc_77487.Models.RiskRating.Medium ? "warning" : "danger")">
                                @item.RiskRating
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No premises found.</div>
    }
</div>
