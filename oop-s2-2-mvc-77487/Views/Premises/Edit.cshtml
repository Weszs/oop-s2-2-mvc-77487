@model oop_s2_2_mvc_77487.Models.Premises

@{
    ViewData["Title"] = "Edit Premises";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1>Edit Premises</h1>

            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Town" class="form-label"></label>
                    <input asp-for="Town" class="form-control" />
                    <span asp-validation-for="Town" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="RiskRating" class="form-label"></label>
                    <select asp-for="RiskRating" class="form-select">
                        <option value="">Select Risk Rating</option>
                        <option value="Low" selected="@(Model.RiskRating == oop_s2_2_mvc_77487.Models.RiskRating.Low)">Low</option>
                        <option value="Medium" selected="@(Model.RiskRating == oop_s2_2_mvc_77487.Models.RiskRating.Medium)">Medium</option>
                        <option value="High" selected="@(Model.RiskRating == oop_s2_2_mvc_77487.Models.RiskRating.High)">High</option>
                    </select>
                    <span asp-validation-for="RiskRating" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
