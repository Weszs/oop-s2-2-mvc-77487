@model oop_s2_2_mvc_77487.Models.Inspection

@{
    ViewData["Title"] = "Inspection Details";
}

<div class="container mt-5">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Inspection Details</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
            }
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <p><strong>Premises:</strong> <a asp-controller="Premises" asp-action="Details" asp-route-id="@Model.PremisesId">@Model.Premises?.Name</a></p>
            <p><strong>Date:</strong> @Model.InspectionDate.ToString("yyyy-MM-dd HH:mm")</p>
            <p><strong>Score:</strong> @Model.Score/100</p>
            <p>
                <strong>Outcome:</strong>
                <span class="badge bg-@(Model.Outcome == oop_s2_2_mvc_77487.Models.InspectionOutcome.Pass ? "success" : "danger")">
                    @Model.Outcome
                </span>
            </p>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <p><strong>Notes:</strong> @Model.Notes</p>
            }
        </div>
    </div>

    <h3>Follow-ups</h3>
    @if (Model.FollowUps.Any())
    {
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Closed Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var followUp in Model.FollowUps.OrderBy(f => f.Status).ThenBy(f => f.DueDate))
                {
                    <tr>
                        <td>@followUp.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge bg-@(followUp.Status == oop_s2_2_mvc_77487.Models.FollowUpStatus.Open ? "warning" : "success")">
                                @followUp.Status
                            </span>
                        </td>
                        <td>@(followUp.ClosedDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                        <td><a asp-controller="FollowUps" asp-action="Details" asp-route-id="@followUp.Id" class="btn btn-sm btn-info">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No follow-ups for this inspection.</div>
    }

    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <div class="mt-3">
            <a asp-controller="FollowUps" asp-action="Create" asp-route-inspectionId="@Model.Id" class="btn btn-success">Create Follow-up</a>
        </div>
    }
</div>
